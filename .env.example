# Copy values into `frontend/.env.local` and `backend/.env` (see README).
# Never commit real secrets — this file is safe to commit.

# -----------------------------------------------------------------------------
# Database (backend) — matches docker-compose.yml Postgres service by default
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://resume_roast:resume_roast@127.0.0.1:5434/resume_roast
# Optional: host port for docker-compose (default 5434 in compose file)
# POSTGRES_PUBLISH_PORT=5434
# PORT=4000

# -----------------------------------------------------------------------------
# Auth — use the SAME NEXTAUTH_SECRET in frontend/.env.local and backend/.env
# -----------------------------------------------------------------------------
# NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# NEXTAUTH_URL=http://localhost:3009
# BACKEND_URL=http://127.0.0.1:4000
# INTERNAL_AUTH_SECRET=optional-shared-secret-for-backend-verify-route

# -----------------------------------------------------------------------------
# LLM providers (backend) — set at least one for roasts
# -----------------------------------------------------------------------------
# GROQ_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Custom OpenAI-compatible API (backend)
# CUSTOM_LLM_BASE_URL=
# CUSTOM_LLM_MODEL=
# CUSTOM_LLM_API_KEY=

# -----------------------------------------------------------------------------
# Embeddings / RAG (backend) — required for npm run rag:ingest and live retrieval
# -----------------------------------------------------------------------------
# NOMIC_API_KEY=
# NOMIC_EMBEDDING_MODEL=nomic-embed-text-v1.5
# EMBEDDING_PROVIDER=nomic
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=

# Disable vector retrieval (baseline experiments)
# RAG_DISABLE=false

# -----------------------------------------------------------------------------
# Optional logging / moderation (backend)
# -----------------------------------------------------------------------------
# ROAST_LOG_STORE_FULL_TEXT=false
# ROAST_LOG_STORE_EXCERPT_CHARS=500
