{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "lib/**/*.ts",
    "db/**/*.ts",
    "scripts/**/*.ts",
    "__tests__/**/*.ts",
    "vitest.config.ts"
  ]
}
