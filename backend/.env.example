# Copy to `backend/.env` (gitignored). Never put real secrets in `.env.example`.
# For `docker compose`, the same keys can live in repo-root `.env`; Compose also mounts
# `backend/.env` into the API container when present.

# -----------------------------------------------------------------------------
# LLM (at least one chat provider for roasts)
# -----------------------------------------------------------------------------
# Free tier: https://console.groq.com/keys
GROQ_API_KEY=
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# -----------------------------------------------------------------------------
# Database (Postgres + pgvector)
# -----------------------------------------------------------------------------
# Local Docker: `docker compose up -d postgres` — default published port 5434
DATABASE_URL=postgresql://resume_roast:resume_roast@127.0.0.1:5434/resume_roast

# -----------------------------------------------------------------------------
# Auth (must match `frontend/.env.local` for NEXTAUTH_SECRET / INTERNAL_AUTH_SECRET)
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3009
INTERNAL_AUTH_SECRET=

# -----------------------------------------------------------------------------
# Embeddings / RAG (optional; required for `npm run rag:ingest` and live RAG)
# -----------------------------------------------------------------------------
# https://atlas.nomic.ai/ or use OpenAI embeddings via OPENAI_API_KEY
# NOMIC_API_KEY=
# EMBEDDING_PROVIDER=nomic
# RAG_DISABLE=false

# -----------------------------------------------------------------------------
# Custom OpenAI-compatible API (optional)
# -----------------------------------------------------------------------------
# CUSTOM_LLM_BASE_URL=
# CUSTOM_LLM_MODEL=
# CUSTOM_LLM_API_KEY=
